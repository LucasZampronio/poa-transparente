{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Requests/s",
      "id": 1,
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum(rate(poa_api_requests_total[1m]))"}
      ]
    },
    {
      "type": "stat",
      "title": "Latência p95",
      "id": 2,
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum(rate(poa_api_request_duration_seconds_bucket[5m])) by (le))"}
      ]
    },
    {
      "type": "stat",
      "title": "Total gasto carregado",
      "id": 3,
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "poa_total_expense_value"}
      ]
    },
    {
      "type": "stat",
      "title": "Total registros",
      "id": 4,
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "poa_total_expense_rows"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests por rota",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(poa_api_requests_total[1m])) by (route, status_code)",
          "legendFormat": "{{route}} {{status_code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latência por rota",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(poa_api_request_duration_seconds_sum[1m])) by (route) / sum(rate(poa_api_request_duration_seconds_count[1m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    }
  ],
