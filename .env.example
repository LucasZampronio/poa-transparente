# -----------------------------------------------------------------------------
# POA TRANSPARENTE - TEMPLATE DE AMBIENTE
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env real!
# -----------------------------------------------------------------------------

# --- BANCO DE DADOS (PostgreSQL) ---
POSTGRES_USER=poa
POSTGRES_PASSWORD=poa
POSTGRES_DB=poa_transparente
# URL de conexão usada pela API e ETL (Dentro do Docker use 'postgres' como host)
DATABASE_URL=postgresql://poa:poa@postgres:5432/poa_transparente

# --- MONITORAMENTO (Grafana) ---
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# --- SEGURANÇA ---
# Secret para assinatura de tokens JWT (se aplicável)
JWT_SECRET=mudar_em_producao

# --- INTEGRAÇÕES (OBRIGATÓRIO EM PRODUÇÃO) ---
# Obtenha em: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
PORTAL_TRANSPARENCIA_API_KEY=
# Token de acesso ao Portal de Dados Abertos de Porto Alegre
CONECTA_GOV_TOKEN=

# --- CONFIGURAÇÕES DE REDE ---
PORT=4000
# Porta exposta para o frontend (Use 80 em produção, 8080 local se houver conflito)
WEB_PORT=80
NODE_ENV=production
# IP Público da VM na Oracle Cloud (Ex: http://123.123.123.123:4000)
VITE_API_URL=
